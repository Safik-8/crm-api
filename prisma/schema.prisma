generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════
// COMPANY & BRANCH
// ══════════════════════════════════════

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches    Branch[]
  users       User[]
  userRoles   UserRole[]
  pipelines   Pipeline[]
  leadSources LeadSource[]

  @@map("companies")
}

model Branch {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String
  code      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  users              User[]
  userRoles          UserRole[]
  pipelines          Pipeline[]
  dailyBranchReports DailyBranchReport[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
  @@map("branches")
}

// ══════════════════════════════════════
// USERS ROLES & PERMISSIONS
// ══════════════════════════════════════

model User {
  id           Int       @id @default(autoincrement())
  companyId    Int?      @map("company_id")
  branchId     Int?      @map("branch_id")
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  status       String    @default("ACTIVE")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company                   Company?            @relation(fields: [companyId], references: [id])
  branch                    Branch?             @relation(fields: [branchId], references: [id])
  userRoles                 UserRole[]          @relation("UserToUserRole")
  assignedRoles             UserRole[]          @relation("AssignedByToUserRole")
  refreshTokens             RefreshToken[]
  createdLeads              Lead[]              @relation("UserCreatedLeads")
  assignedLeads             Lead[]              @relation("UserAssignedLeads")
  stageChangedLeads         Lead[]              @relation("UserStageChangedLeads")
  leadComments              LeadComment[]
  createdDailyBranchReports DailyBranchReport[] @relation("UserCreatedDailyBranchReports")

  @@index([companyId])
  @@index([branchId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles       UserRole[]
  rolePermissions Permission[]

  @@map("roles")
}

model UserRole {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  companyId  Int?     @map("company_id")
  branchId   Int?     @map("branch_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy Int?     @map("assigned_by")

  user           User     @relation("UserToUserRole", fields: [userId], references: [id])
  role           Role     @relation(fields: [roleId], references: [id])
  company        Company? @relation(fields: [companyId], references: [id])
  branch         Branch?  @relation(fields: [branchId], references: [id])
  assignedByUser User?    @relation("AssignedByToUserRole", fields: [assignedBy], references: [id])

  @@unique([userId, roleId, companyId, branchId])
  @@map("user_roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  roleId    Int      @map("role_id")
  module    String
  canView   Boolean  @default(false) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at")

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, module])
  @@map("permissions")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// ══════════════════════════════════════════════════════════
// SPRINT 2 — ADD TO BOTTOM OF schema.prisma
// ══════════════════════════════════════════════════════════

// ── LEAD SOURCE ────────────────────────────────────────────
// Proper table instead of raw String on Prospect
// companyId = null means global/system default for all companies
// Ensures consistent values in reports and dropdowns

model LeadSource {
  id        Int       @id @default(autoincrement())
  companyId Int?      @map("company_id")
  name      String
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("lead_sources")
}

// ══════════════════════════════════════
// PIPELINE MANAGEMENT
// ══════════════════════════════════════

// Pipeline belongs to a branch
// One branch can have multiple pipelines

model Pipeline {
  id          Int      @id @default(autoincrement())
  branchId    Int      @map("branch_id")
  companyId   Int      @map("company_id")
  name        String
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdById Int      @map("created_by")
  updatedById Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch  Branch          @relation(fields: [branchId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])
  stages  PipelineStage[]
  leads   Lead[]

  @@index([branchId])
  @@index([companyId])
  @@map("pipelines")
}

// ══════════════════════════════════════
// STAGE MASTER
// Global stages shared across all pipelines
// is_default = true means "Prospect" stage
// ══════════════════════════════════════

model Stage {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  isDefault   Boolean  @default(false) @map("is_default")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdById Int      @map("created_by")
  updatedById Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pipelineStages   PipelineStage[]
  leads            Lead[]
  leadsPreviousStage Lead[] @relation("LeadPreviousStage")

  @@map("stages")
}

// ══════════════════════════════════════
// PIPELINE STAGES MAPPING
// Links stages to pipelines with order
// ══════════════════════════════════════

model PipelineStage {
  id         Int @id @default(autoincrement())
  pipelineId Int @map("pipeline_id")
  stageId    Int @map("stage_id")
  orderNo    Int @map("order_no")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  stage    Stage    @relation(fields: [stageId], references: [id])

  @@unique([pipelineId, stageId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

// ══════════════════════════════════════
// LEAD
// ══════════════════════════════════════

model Lead {
  id            Int      @id @default(autoincrement())
  pipelineId    Int      @map("pipeline_id")
  stageId       Int      @map("stage_id")
  previousStageId Int?   @map("previous_stage_id")
  stageChangedById Int?  @map("stage_changed_by_id")
  stageChangedAt DateTime? @map("stage_changed_at")
  assignedToId  Int?     @map("assigned_to")
  name          String
  mobile        String
  date          DateTime
  interestedFor String?  @map("interested_for")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdById   Int      @map("created_by")
  updatedById   Int?     @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  pipeline       Pipeline      @relation(fields: [pipelineId], references: [id])
  stage          Stage         @relation(fields: [stageId], references: [id])
  previousStage  Stage?        @relation("LeadPreviousStage", fields: [previousStageId], references: [id])
  stageChangedBy User?         @relation("UserStageChangedLeads", fields: [stageChangedById], references: [id])
  createdBy      User          @relation("UserCreatedLeads", fields: [createdById], references: [id])
  assignedTo     User?         @relation("UserAssignedLeads", fields: [assignedToId], references: [id])
  comments       LeadComment[]

  @@index([pipelineId])
  @@index([stageId])
  @@index([previousStageId])
  @@index([assignedToId])
  @@map("leads")
}

// ══════════════════════════════════════
// LEAD COMMENT
// ══════════════════════════════════════

model LeadComment {
  id          Int      @id @default(autoincrement())
  leadId      Int      @map("lead_id")
  userId      Int      @map("user_id")
  comment     String
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdById Int      @map("created_by")
  updatedById Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("lead_comments")
}

//===========================================================================================
// daily_branch_reports
//===========================================================================================

model DailyBranchReport {
  id Int @id @default(autoincrement())

  branchId   Int      @map("branch_id")
  reportDate DateTime @map("report_date") // store date-only at 00:00:00

  callsReceived      Int     @default(0) @map("calls_received")
  qualifiedLeads     Int     @default(0) @map("qualified_leads")
  counsellingDone    Int     @default(0) @map("counselling_done")
  counsellingBooked  Int     @default(0) @map("counselling_booked")
  officeVisits       Int     @default(0) @map("office_visits")
  closures           Int     @default(0) @map("closures")
  followupsDone      Int     @default(0) @map("followups_done")
  pendingFollowups   Int     @default(0) @map("pending_followups")

  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdById Int      @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  // updatedAt removed: daily reports are submit-once (no updates)

  branch    Branch @relation(fields: [branchId], references: [id])
  createdBy User   @relation("UserCreatedDailyBranchReports", fields: [createdById], references: [id])

  // multiple users can submit for same branch+date, but each user only once
  @@unique([branchId, reportDate, createdById])
  @@index([branchId])
  @@index([createdById])
  @@map("daily_branch_reports")
}
