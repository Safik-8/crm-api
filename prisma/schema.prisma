  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
  }

  // ══════════════════════════════════════
  // COMPANY & BRANCH
  // ══════════════════════════════════════

  model Company {
    id        Int      @id @default(autoincrement())
    name      String
    code      String   @unique
    status    String   @default("ACTIVE")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt      @map("updated_at")

    branches  Branch[]
    users     User[]
    userRoles UserRole[]

    prospects  Prospect[]
    leadSources LeadSource[]  

    @@map("companies")
  }

  model Branch {
    id        Int      @id @default(autoincrement())
    companyId Int      @map("company_id")
    name      String
    code      String
    status    String   @default("ACTIVE")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt      @map("updated_at")

    company   Company  @relation(fields: [companyId], references: [id])
    users     User[]
    userRoles UserRole[]

    branchSequence BranchSequence?
    prospects Prospect[]

    @@unique([companyId, code])
    @@index([companyId])
    @@index([code])
    @@map("branches")
  }

  // ══════════════════════════════════════
  // USERS ROLES & PERMISSIONS
  // ══════════════════════════════════════

  model User {
    id          Int       @id @default(autoincrement())
    companyId   Int?      @map("company_id")
    branchId    Int?      @map("branch_id")
    name        String
    email       String    @unique
    passwordHash String   @map("password_hash")
    status      String    @default("ACTIVE")
    lastLoginAt DateTime? @map("last_login_at")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt      @map("updated_at")

    company       Company?  @relation(fields: [companyId], references: [id])
    branch        Branch?   @relation(fields: [branchId],  references: [id])
    userRoles     UserRole[] @relation("UserToUserRole")
    assignedRoles UserRole[] @relation("AssignedByToUserRole")
    refreshTokens RefreshToken[]

    assignedProspects Prospect[] @relation("ProspectAssignedTo")
    createdProspects  Prospect[] @relation("ProspectCreatedBy")
    stageHistories    StageHistory[]

    @@index([companyId])
    @@index([branchId])
    @@map("users")
  }

  model Role {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    description String?
    createdAt   DateTime @default(now()) @map("created_at")

    userRoles       UserRole[]
    rolePermissions Permission[]

    @@map("roles")
  }

  model UserRole {
    id         Int      @id @default(autoincrement())
    userId     Int      @map("user_id")
    roleId     Int      @map("role_id")
    companyId  Int?     @map("company_id")
    branchId   Int?     @map("branch_id")
    isPrimary  Boolean  @default(false) @map("is_primary")
    assignedAt DateTime @default(now()) @map("assigned_at")
    assignedBy Int?     @map("assigned_by")

    user           User     @relation("UserToUserRole",       fields: [userId],     references: [id])
    role           Role     @relation(fields: [roleId],       references: [id])
    company        Company? @relation(fields: [companyId],    references: [id])
    branch         Branch?  @relation(fields: [branchId],     references: [id])
    assignedByUser User?    @relation("AssignedByToUserRole", fields: [assignedBy], references: [id])

    @@unique([userId, roleId, companyId, branchId])
    @@map("user_roles")
  }

  model Permission {
    id        Int      @id @default(autoincrement())
    roleId    Int      @map("role_id")
    module    String
    canView   Boolean  @default(false) @map("can_view")
    canCreate Boolean  @default(false) @map("can_create")
    canEdit   Boolean  @default(false) @map("can_edit")
    canDelete Boolean  @default(false) @map("can_delete")
    createdAt DateTime @default(now()) @map("created_at")

    role Role @relation(fields: [roleId], references: [id])

    @@unique([roleId, module])
    @@map("permissions")
  }

  model RefreshToken {
    id        Int      @id @default(autoincrement())
    userId    Int      @map("user_id")
    token     String   @unique
    expiresAt DateTime @map("expires_at")
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id])

    @@index([userId])
    @@map("refresh_tokens")
  }

  // ══════════════════════════════════════════════════════════
// SPRINT 2 — ADD TO BOTTOM OF schema.prisma
// ══════════════════════════════════════════════════════════

// ── BRANCH SEQUENCE ────────────────────────────────────────
// Generates prospect codes like ACME-MUM-0001
// Each branch has its own counter independently
// Atomic SQL increment prevents duplicates under concurrency

model BranchSequence {
  id        Int @id @default(autoincrement())
  branchId  Int @unique @map("branch_id")
  companyId Int @map("company_id")
  lastSeq   Int @default(0) @map("last_seq")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_sequences")
}

// ── LEAD SOURCE ────────────────────────────────────────────
// Proper table instead of raw String on Prospect
// companyId = null means global/system default for all companies
// Ensures consistent values in reports and dropdowns

model LeadSource {
  id        Int      @id @default(autoincrement())
  companyId Int?     @map("company_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  company   Company?   @relation(fields: [companyId], references: [id])
  prospects Prospect[]

  @@unique([companyId, name])
  @@map("lead_sources")
}

// ── PROSPECT ───────────────────────────────────────────────
// Core prospect table
// currentStage uses enum — DB rejects invalid values
// leadSourceId is FK — no typo differences

model Prospect {
  id           Int           @id @default(autoincrement())
  prospectCode String        @unique @map("prospect_code")
  name         String
  mobile       String
  email        String?
  education    String?
  college      String?
  city         String?

  leadSourceId Int           @map("lead_source_id")
  currentStage ProspectStage @default(NEW) @map("current_stage")

  // Win fields — both required before moving to WIN stage
  tokenAmount     Decimal?  @map("token_amount")      @db.Decimal(12, 2)
  joiningDate     DateTime? @map("joining_date")
  expectedRevenue Decimal?  @map("expected_revenue")  @db.Decimal(12, 2)
  winDate         DateTime? @map("win_date")

  // Duplicate tracking (BE-2-03)
  duplicateAcknowledged Boolean @default(false) @map("duplicate_acknowledged")

  // Archive tracking — unarchive requires managerApprovalId (BE-2-04)
  archivedAt        DateTime? @map("archived_at")
  archivedById      Int?      @map("archived_by_id")
  managerApprovalId Int?      @map("manager_approval_id")
  unarchivedAt      DateTime? @map("unarchived_at")
  unarchivedById    Int?      @map("unarchived_by_id")

  assignedToId   Int       @map("assigned_to_id")
  createdById    Int       @map("created_by_id")
  companyId      Int       @map("company_id")
  branchId       Int       @map("branch_id")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  company    Company    @relation(fields: [companyId],    references: [id])
  branch     Branch     @relation(fields: [branchId],     references: [id])
  leadSource LeadSource @relation(fields: [leadSourceId], references: [id])
  assignedTo User       @relation("ProspectAssignedTo",   fields: [assignedToId], references: [id])
  createdBy  User       @relation("ProspectCreatedBy",    fields: [createdById],  references: [id])

  stageHistory StageHistory[]

  @@index([companyId])
  @@index([branchId])
  @@index([assignedToId])
  @@index([currentStage])
  @@index([mobile, companyId])  // used by duplicate check query
  @@index([createdAt])
  @@map("prospects")
}

// ── STAGE HISTORY ──────────────────────────────────────────
// Every stage change is recorded here — never deleted
// oldStage is nullable — null means prospect was just created (initial NEW entry)

model StageHistory {
  id          Int            @id @default(autoincrement())
  prospectId  Int            @map("prospect_id")
  oldStage    ProspectStage? @map("old_stage")  // null = initial creation
  newStage    ProspectStage  @map("new_stage")
  changedById Int            @map("changed_by_id")
  changedAt   DateTime       @default(now()) @map("changed_at")
  note        String?

  prospect  Prospect @relation(fields: [prospectId],  references: [id])
  changedBy User     @relation(fields: [changedById], references: [id])

  @@index([prospectId])
  @@map("stage_history")
}

// ══════════════════════════════════════════════════════════
// SPRINT 2 ENUM
// ══════════════════════════════════════════════════════════

enum ProspectStage {
  NEW
  ENGAGED
  STRATEGY_SCHEDULED
  STRATEGY_COMPLETED
  TOKEN_DISCUSSION
  TOKEN_RECEIVED
  WIN
  ARCHIVED
}